# ─── Household API - Environment Variables ─────────────────────────────────────
# Copy this file to .env and fill in your values.
# This file is loaded automatically in development.
# In production (Docker / CasaOS), set these as container environment variables.

# ────────────────────────────────────────────────────────────────────────────────
# DATABASE
# ────────────────────────────────────────────────────────────────────────────────
# Path inside the container. Map to a persistent Docker volume.
DATABASE_PATH=/data/household.db

# ────────────────────────────────────────────────────────────────────────────────
# JWT
# ────────────────────────────────────────────────────────────────────────────────
# REQUIRED. Must be a long random string (min 32 chars).
JWT_SECRET_KEY=CHANGE_ME_TO_A_LONG_RANDOM_STRING_32_CHARS_MIN

JWT_ISSUER=Household.Api
JWT_AUDIENCE=Household.Client
JWT_ACCESS_TOKEN_MINUTES=15
JWT_REFRESH_TOKEN_DAYS=30

# ────────────────────────────────────────────────────────────────────────────────
# CORS
# ────────────────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Example for LAN: http://192.168.1.10:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ────────────────────────────────────────────────────────────────────────────────
# SEED (initial admin user)
# ────────────────────────────────────────────────────────────────────────────────
# Set SEED_ADMIN_ENABLED=true only on first boot of a fresh installation.
# After the admin is created, set it back to false to prevent accidental re-seeding.
SEED_ADMIN_ENABLED=false
SEED_ADMIN_EMAIL=admin@local
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=Admin123!123!

# Demo/sample data (rooms, tasks, food). Only for development/testing.
DEMO_DATA_ENABLED=false

# ────────────────────────────────────────────────────────────────────────────────
# MEAL TYPE TIME RANGES (optional - defaults are sensible)
# ────────────────────────────────────────────────────────────────────────────────
#MEAL_BREAKFAST_START=07:00
#MEAL_BREAKFAST_END=10:30
#MEAL_MORNING_SNACK_START=10:30
#MEAL_MORNING_SNACK_END=12:00
#MEAL_LUNCH_START=12:00
#MEAL_LUNCH_END=15:30
#MEAL_AFTERNOON_SNACK_START=15:30
#MEAL_AFTERNOON_SNACK_END=20:00
#MEAL_DINNER_START=20:00
#MEAL_DINNER_END=23:59
