{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information",
      "Microsoft.EntityFrameworkCore": "Information"
    }
  },

  "DatabaseSettings": {
    "DatabasePath": "../household-dev.db",
    "EnableSensitiveDataLogging": true
  },

  "JwtSettings": {
    "SecretKey": "DevOnlySecretKeyThatIsAtLeast32CharactersLong!",
    "Issuer": "Household.Api.Dev",
    "Audience": "Household.Client.Dev",
    "AccessTokenMinutes": 60,
    "RefreshTokenDays": 7
  },

  "CorsSettings": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "http://localhost:5173",
      "http://localhost:8080"
    ]
  },

  "SeedSettings": {
    "AdminEnabled": true,
    "AdminEmail": "admin@local",
    "AdminUsername": "admin",
    "AdminPassword": "Admin123!",
    "DemoDataEnabled": false
  }
}
